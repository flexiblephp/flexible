{
  "name": "flexible/framework",
  "type": "project",
  "description": "The Flexible Framework.",
  "keywords": [
    "framework",
    "php"
  ],
  "homepage": "https://flexiblephp.github.io/",
  "license": "MIT",
  "authors": [
    {
      "name": "Marc Guinea",
      "email": "marcguinea+flexible@gmail.com",
      "homepage": "https://marcguinea.com"
    }
  ],
  "require": {
    "php": "^7.4|^8.0",
    "psr/container": "^2.0",
    "psr/http-client": "^1.0",
    "psr/http-factory": "^1.0",
    "psr/http-server-handler": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "Flexible\\Framework\\": ""
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
