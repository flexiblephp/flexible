{
  "name": "flexible/config",
  "type": "package",
  "description": "The Flexible Config component.",
  "keywords": [
    "configuration",
    "settings",
    "component"
  ],
  "homepage": "https://flexiblephp.github.io/",
  "license": "MIT",
  "authors": [
    {
      "name": "Marc Guinea",
      "email": "marcguinea+flexible@gmail.com",
      "homepage": "https://marcguinea.com"
    }
  ],
  "require": {
    "php": "^7.4|^8.0"
  },
  "autoload": {
    "psr-4": {
      "Flexible\\Config\\": ""
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "1.x-dev"
    }
  },
  "config": {
    "optimize-autoloader": true,
    "preferred-install": "dist",
    "sort-packages": true
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}
